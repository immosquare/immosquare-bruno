meta {
  name: Get Property Green Verification by Key
  type: http
  seq: 22
}

get {
  url: {{baseUrl}}/v1/odata/PropertyGreenVerification('{{greenBuildingVerificationKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  greenBuildingVerificationKey:
}

docs {
  Récupère une certification écologique par sa clé (GreenBuildingVerificationKey).
  Définir greenBuildingVerificationKey dans les variables avant exécution.
}
