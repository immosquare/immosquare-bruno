meta {
  name: Get Property Animal by Key
  type: http
  seq: 26
}

get {
  url: {{baseUrl}}/v1/odata/PropertyAnimal('{{animalKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  animalKey:
}

docs {
  Récupère un animal de propriété par sa clé (AnimalKey).
  Définir animalKey dans les variables avant exécution.
}
