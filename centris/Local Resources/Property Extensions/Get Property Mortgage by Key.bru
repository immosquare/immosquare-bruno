meta {
  name: Get Property Mortgage by Key
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/v1/odata/PropertyMortgage('{{mortgageKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  mortgageKey:
}

docs {
  Récupère une hypothèque spécifique par sa clé (MortgageKey).
  Définir mortgageKey dans les variables avant exécution.
}
