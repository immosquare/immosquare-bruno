meta {
  name: Get Property Unit by Key
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/v1/odata/PropertyUnit('{{unitKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  unitKey:
}

docs {
  Récupère une unité spécifique par sa clé (UnitKey).
  Définir unitKey dans les variables avant exécution.
}
