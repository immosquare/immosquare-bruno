meta {
  name: Get Additional Space by Key
  type: http
  seq: 20
}

get {
  url: {{baseUrl}}/v1/odata/PropertyAdditionalSpace('{{additionalSpaceKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  additionalSpaceKey:
}

docs {
  Récupère un espace additionnel par sa clé (AdditionalSpaceKey).
  Définir additionalSpaceKey dans les variables avant exécution.
}
