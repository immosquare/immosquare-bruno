meta {
  name: Get Property Subdivision by Key
  type: http
  seq: 40
}

get {
  url: {{baseUrl}}/v1/odata/PropertySubdivision('{{subdivisionKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  subdivisionKey:
}

docs {
  Récupère une subdivision par sa clé (SubdivisionKey).
  Définir subdivisionKey dans les variables avant exécution.
}
