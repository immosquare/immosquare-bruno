meta {
  name: Get Property Parking by Key
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/v1/odata/PropertyParking('{{parkingKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  parkingKey:
}

docs {
  Récupère un stationnement spécifique par sa clé (ParkingKey).
  Définir parkingKey dans les variables avant exécution.
}
