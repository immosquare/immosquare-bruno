meta {
  name: Get Street by Key
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/v1/odata/Street('{{streetKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  streetKey:
}

docs {
  Récupère une rue spécifique par sa clé (StreetKey).
  Définir streetKey dans les variables avant exécution.
}
