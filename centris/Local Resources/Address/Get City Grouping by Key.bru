meta {
  name: Get City Grouping by Key
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/v1/odata/CityOrTownshipGrouping('{{cityOrTownshipGroupingKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  cityOrTownshipGroupingKey:
}

docs {
  Récupère un regroupement de villes par sa clé (CityOrTownshipGroupingKey).
  Définir cityOrTownshipGroupingKey dans les variables avant exécution.
}
