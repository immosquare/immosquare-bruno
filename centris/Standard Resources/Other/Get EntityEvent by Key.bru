meta {
  name: Get EntityEvent by Key
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/v1/odata/EntityEvent('{{entityEventKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  entityEventKey:
}

docs {
  Récupère un événement d'entité par sa clé (EntityEventKey).
  Définir entityEventKey dans les variables avant exécution.
}
