meta {
  name: Get Association by Key
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/v1/odata/Association('{{associationKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  associationKey:
}

docs {
  Récupère une association spécifique par sa clé (AssociationKey).
  Définir associationKey dans les variables avant exécution.
}
