meta {
  name: Get SocialMedia by Key
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/v1/odata/SocialMedia('{{socialMediaKey}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  socialMediaKey:
}

docs {
  Récupère un lien de média social par sa clé (SocialMediaKey).
  Définir socialMediaKey dans les variables avant exécution.
}
