meta {
  name: Get OUID by Key
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/v1/odata/OUID('{{organizationUniqueId}}')
  body: none
  auth: bearer
}

params:query {
}

auth:bearer {
  token: {{apiKey}}
}

vars:pre-request {
  organizationUniqueId:
}

docs {
  Récupère un OUID spécifique par sa clé (OrganizationUniqueId).
  Définir organizationUniqueId dans les variables avant exécution.
}
