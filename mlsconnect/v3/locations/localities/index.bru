meta {
  name: index
  type: http
  seq: 1
}

get {
  url: https://{{baseurl}}/v3/locations/localities
  body: none
  auth: inherit
}

params:query {
  ~country: abc123
  ~administrative_area_level1: abc123
  ~administrative_area_level2: abc123
  ~zip_code: 06000
  ~search: nice
}

headers {
  apiKey: {{apiKey}}
  apiToken: {{apiToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
