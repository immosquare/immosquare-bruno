meta {
  name: agency get users sectors
  type: http
  seq: 10
}

post {
  url: https://{{baseurl}}/v1/logiciel/agency/user_sectors?agency_login={{agency_login}}&agency_pass={{agency_pass}}
  body: none
  auth: none
}

query {
  agency_login: {{agency_login}}
  agency_pass: {{agency_pass}}
}

headers {
  apiKey: {{apiKey}}
  apiToken: {{apiToken}}
}
